# App
APP_PORT=3000
APP_SITE_URL=http://localhost:3000

# Supabase (local CLI / public client)
SUPABASE_PUBLIC_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-long-jwt-secret
SUPABASE_JWT_EXP=3600
POSTGRES_DB=postgres
POSTGRES_PASSWORD=your-postgres-password
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_URI_ALLOW_LIST=

# Coolify self-hosted Supabase reference
# NEXT_PUBLIC_SUPABASE_URL=https://supabase.your-domain.com
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<copy the anon key from the Coolify Supabase service>
# SUPABASE_SERVICE_ROLE_KEY=<copy the service_role key from the Coolify Supabase service>
# ALLOWED_ORIGINS=https://app.your-domain.com

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_AUDIO_MODEL=whisper-1

# AI Service
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000
