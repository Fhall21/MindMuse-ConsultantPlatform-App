# App
APP_PORT=3000
APP_SITE_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# PostgreSQL + Drizzle
# These are the only database vars you need to set for this project.
# The bundled Postgres container maps them to its internal POSTGRES_* vars automatically.
DATABASE_NAME=consultant_platform
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
# Optional direct URL for non-Compose local scripts.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/consultant_platform

# Optional fallback mode for non-Compose local setups:
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432

# Coolify PostgreSQL reference
# Compose/Coolify do not use DATABASE_URL. They wire containers together with:
# DATABASE_HOST=db
# DATABASE_PORT=5432
# DATABASE_NAME=consultant_platform
# DATABASE_USER=postgres
# DATABASE_PASSWORD=<password>
# For manual Docker-based migrations on the server:
# MIGRATION_NETWORK=<coolify project network name>
# DB_MIGRATION_MAX_ATTEMPTS=20
# DB_MIGRATION_RETRY_DELAY_SECONDS=5
# For the bundled AI service, AI_SERVICE_URL can stay unset in Coolify and will default
# to the internal service URL. Set it only if you want to override that behavior.
# AI_SERVICE_URL=http://ai:8000

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_AUDIO_MODEL=whisper-1

# AI Service
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
