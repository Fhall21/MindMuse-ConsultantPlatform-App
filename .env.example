# App
APP_PORT=3000
APP_SITE_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Coolify deployment notes:
# - Set APP_SITE_URL to your public app URL, for example https://consultant.mindmuse.care
# - Keep AI_SERVICE_URL internal inside the compose network, for example http://ai:8000
#   (do NOT use http://localhost:8000 in production — the app rejects localhost AI URLs)
# - BETTER_AUTH_SECRET must be set once in Coolify and is injected into BOTH the `app` and
#   `ai` services (see docker-compose.coolify.yml). Same value on both — required for
#   meetings-page theme extraction and other /api/* → FastAPI proxies after Sprint 21.
# - Only set ALLOWED_ORIGINS on the AI service if you expose it publicly (optional; app→ai
#   server-side calls do not need CORS)
#
# If live theme extraction returns {"detail":"Unauthorized"} but local works:
# 1. Redeploy app + ai after pulling the proxy Bearer-token fix (lib/api/route-helpers.ts).
# 2. Confirm BETTER_AUTH_SECRET is identical on app and ai (one Coolify env var).
# 3. Confirm APP_SITE_URL matches the browser URL (auth cookies).
# 4. If the error becomes "Invalid or expired service token", the secret differs between services.

# PostgreSQL + Drizzle
# These are the only database vars you need to set for this project.
# The bundled Postgres container maps them to its internal POSTGRES_* vars automatically.
DATABASE_NAME=consultant_platform
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
# Optional direct URL for non-Compose local scripts.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/consultant_platform

# Optional fallback mode for non-Compose local setups:
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432

# Coolify PostgreSQL reference
# Compose/Coolify do not use DATABASE_URL. They wire containers together with:
# DATABASE_HOST=db
# DATABASE_PORT=5432
# DATABASE_NAME=consultant_platform
# DATABASE_USER=postgres
# DATABASE_PASSWORD=<password>
# For manual Docker-based migrations on the server:
# MIGRATION_NETWORK=<coolify project network name>
# DB_MIGRATION_MAX_ATTEMPTS=20
# DB_MIGRATION_RETRY_DELAY_SECONDS=5
# For the bundled AI service, AI_SERVICE_URL can stay unset in Coolify and will default
# to the internal service URL. Set it only if you want to override that behavior.
# AI_SERVICE_URL=http://ai:8000

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_AUDIO_MODEL=whisper-1

# Chat agent (Next.js /api/chat — Vercel AI SDK)
CHAT_MODEL=gpt-5.4-mini
# Set true to expose old stats dashboard at /dashboard/legacy
FEATURE_LEGACY_DASHBOARD=false

# AI Service
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000
EDISON_API_KEY=
